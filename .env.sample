# ==============================================================================
# 🚀 GARIM 프로젝트 환경 변수 템플릿 (.env.sample)
# ==============================================================================
# [사용 방법]
# 1. 이 파일을 복사하여 `.env` 파일을 생성하세요.
#    (예: 프로젝트 최상단 경로에 `.env` 파일 생성 후 아래 내용 붙여넣기)
# 2. 각 변수에 맞는 실제 발급받은 키 값과 환경에 맞는 주소로 변경하여 사용합니다.
# 3. .env 파일들은 절대 Github에 커밋되지 않도록 주의하세요! (.gitignore에 등록됨)
# ==============================================================================

# ---------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------
POSTGRES_USER=garim_user
POSTGRES_PASSWORD=garim_password
POSTGRES_DB=garim_db
DB_PORT=5432
DB_HOST=final_db

# ---------------------------------------------------------
# Redis
# ---------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://final_redis:6379/0
REDIS_SESSION_TTL_SECONDS=604800
REDIS_OAUTH_STATE_TTL_SECONDS=300
REDIS_DASHBOARD_CACHE_TTL_SECONDS=10
REDIS_PROGRESS_TTL_SECONDS=3600

# ---------------------------------------------------------
# Backend Server
# ---------------------------------------------------------
HOST=0.0.0.0
PORT=8000
AUTH_COOKIE_SECRET=change_this_to_a_secure_random_string_for_production
WORKER_SECRET=change_this_to_another_secure_string

# ---------------------------------------------------------
# Upload & Temp Dirs
# ---------------------------------------------------------
UPLOAD_DIR=storage/uploads
TEMP_DIR=storage/temp
CHUNK_UPLOAD_EXPIRE_HOURS=24

# ---------------------------------------------------------
# Frontend Callback Base URL
# ---------------------------------------------------------
# 로컬 개발 시: http://localhost
# 운영 환경 시: https://your-production-domain.com
FRONTEND_BASE_URL=http://localhost

# ---------------------------------------------------------
# OAuth (소셜 로그인 설정)
# 주의: 콜백 URI는 반드시 백엔드 내부망 주소(예: http://final_backend:8000)가 아닌, 
# 프론트엔드와 Nginx를 거치는 '외부 노출 주소'를 적어주세요.
# (예: 로컬 테스트 시 -> http://localhost/api/v1/auth/kakao/callback)
# (예: 실제 배포 시 -> https://your-domain.com/api/v1/auth/kakao/callback)
# ---------------------------------------------------------
# Kakao
KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost/api/v1/auth/kakao/callback

# Naver
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=http://localhost/api/v1/auth/naver/callback

# Google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback

# ---------------------------------------------------------
# Toss Payments (결제 설정)
# ---------------------------------------------------------
TOSS_CLIENT_KEY=your_toss_client_key
TOSS_SECRET_KEY=your_toss_secret_key
TOSS_SUCCESS_URL=http://localhost/payment/success
TOSS_FAIL_URL=http://localhost/payment/fail

# ---------------------------------------------------------
# Frontend Vite variables (React 환경 변수)
# ---------------------------------------------------------
VITE_API_BASE_URL=/api/v1
VITE_TOSS_CLIENT_KEY=your_toss_client_key

# ---------------------------------------------------------
# Cloudflare Zero Trust Tunnel (옵션 - 포트포워딩 우회 및 외부 공개용)
# ---------------------------------------------------------
# 외부 포트가 막혀있을 때 포트포워딩 없이 도메인으로 서비스할 수 있게 해줍니다.
# Cloudflare Zero Trust 메뉴에서 터널 생성 후 발급받은 토큰을 입력하세요.
# 터널을 사용하지 않을 경우(로컬 테스트만 할 경우) 주석 처리하거나 비워두면 됩니다.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
